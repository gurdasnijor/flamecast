    "knip": "knip --config knip.json --workspace packages/flamecast --workspace examples/agent.js --workspace apps/server --workspace apps/client --no-config-hints",
    "ci:lint": "pnpm lint && pnpm format:check",
    "lint": "oxlint --config .oxlintrc.json --deny-warnings .",
    "lint:fix": "oxlint --config .oxlintrc.json --fix --fix-suggestions --deny-warnings .",
    "format": "oxfmt --config .oxfmtrc.json --write .",
