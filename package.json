    "dev:alchemy": "FLAMECAST_RUNTIME_HOST=remote FLAMECAST_RUNTIME_HOST_URL=http://localhost:9100 CLOUDFLARE_ACCOUNT_ID=c4cf21d8a5e8878bc3c92708b1f80193 CLOUDFLARE_API_TOKEN=\"cfut_61huVAxPaherHE3JYr9C9PoI5qjswYS6NMum2olj0f0e7781\" ALCHEMY_PASSWORD=\"uAokk2ttPrwwdzuwd9g72jz011phuTqjTrYtmF9bMVE=\" npx alchemy dev cloudflare.run.dev.ts",
