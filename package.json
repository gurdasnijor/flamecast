    "deploy:cloudflare": "infisical run --path=/tooling --env=staging --silent --projectId=7cd1c4ac-3fcd-4f5a-be98-51ac45183c18 -- alchemy run cloudflare.run.ts",
    "deploy:vercel": "npx alchemy run vercel.run.ts",
    "build": "turbo run build",
