{
  "$schema": "https://turbo.build/schema.json",
  "futureFlags": { "experimentalObservability": true },
  "globalPassThroughEnv": ["FLAMECAST_AGENT_JS_BASE_URL", "ROUTER_PORT", "RESTATE_INGRESS_URL", "RESTATE_ADMIN_URL", "RESTATE_ENDPOINT_PORT", "FLAMECAST_RUNTIME_HOST", "FLAMECAST_RUNTIME_HOST_URL"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build:package"]
    },
    "dev:server": {
      "cache": false,
      "persistent": true
    },
    "dev:register": {
      "cache": false
    },
    "dev:runtime-host": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build:package"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:package": {
      "dependsOn": ["^build:package"],
      "outputs": ["dist/**"]
    },
    "test": {
      "outputs": []
    },
    "test:api:coverage": {
      "outputs": ["coverage/**"]
    },
    "knip": {
      "outputs": []
    },
    "psql:generate": {
      "cache": false
    }
  }
}
