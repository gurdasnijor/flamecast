{
  "name": "@flamecast/sdk",
  "version": "0.0.0",
  "bin": {
    "flamecast": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./edge": {
      "types": "./src/edge.ts",
      "import": "./src/edge.ts"
    },
    "./acp": {
      "types": "./src/acp/client.ts",
      "import": "./src/acp/client.ts"
    },
    "./client": {
      "types": "./src/client/api.ts",
      "import": "./src/client/api.ts"
    },
    "./restate": {
      "types": "./src/restate/index.ts",
      "import": "./src/restate/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm run build:package",
    "build:package": "tsc -p tsconfig.package.json",
    "start": "node dist/cli.js",
    "dev": "tsx src/restate/serve-endpoint.ts",
    "dev:runtime-host": "tsx src/runtime-host/serve.ts",
    "dev:server": "npx @restatedev/restate-server --config-file=restate.toml",
    "dev:register": "sleep 5 && RESTATE_ADMIN_BASE_URL=http://localhost:19070 npx @restatedev/restate -y deployments register http://localhost:9080",
    "test": "vitest run --config vitest.integration.config.ts",
    "test:api:coverage": "vitest run --coverage --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@flamecast/acp-gateway": "workspace:*",
    "@flamecast/protocol": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@restatedev/pubsub": "^0.1.0",
    "@restatedev/pubsub-client": "^0.1.0",
    "@restatedev/restate-sdk": "^1.5.0",
    "@restatedev/restate-sdk-clients": "^1.5.0",
    "dockerode": "^4.0.10",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@restatedev/restate-sdk-testcontainers": "^1.11.1",
    "@restatedev/restate-server": "^1.6.2",
    "@types/dockerode": "^4.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "knip": "^6.0.1",
    "vitest": "^4.1.0"
  }
}
