{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "react-jsx"
  },
  "include": [
    "src/cli.ts",
    "src/cli-app.ts",
    "src/index.ts",
    "src/edge.ts",
    "src/api.ts",
    "src/flamecast-class.ts",
    "src/shared/**/*.ts",
    "src/restate/**/*.ts",
    "src/runtime/**/*.ts",
    "src/runtime-host/**/*.ts",
    "src/adapters/**/*.ts"
  ],
  "exclude": ["src/runtime-host/strategies/e2b.ts"]
}
